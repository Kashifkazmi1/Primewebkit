# Copy to .env.local for development, or set these in your hosting
# platform's environment configuration for production.

# Public site origin (this Next.js app).
NEXT_PUBLIC_SITE_URL=https://primewebkit.com

# Backend API base URL. In production this is reverse-proxied under
# the same domain (see DEPLOYMENT.md); for local development against
# a locally-running PHP backend, point this at that server directly,
# e.g. http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=https://primewebkit.com/api/v1

# Widget embed script served by the PHP backend.
NEXT_PUBLIC_WIDGET_URL=https://primewebkit.com/widget.js

# Public Google OAuth client ID (not a secret) for Google Identity
# Services sign-in. Must match the backend's GOOGLE_CLIENT_ID and have
# primewebkit.com registered as an Authorized JavaScript origin in
# Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=1044212666179-nmo21qhhgr7hc4n8sdm34ccsgs5sdo84.apps.googleusercontent.com
