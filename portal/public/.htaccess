# Security headers — equivalent to the next.config.ts headers() that
# don't run in static-export mode (no Node.js server to apply them).
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # /chat is meant to be embedded in an iframe on customer sites, so it's
  # excluded from the frame-restriction everything else gets.
  <If "%{REQUEST_URI} !~ m#^/chat#">
    Header always set X-Frame-Options "SAMEORIGIN"
  </If>
</IfModule>

# Every route has a same-named directory sitting next to its .html file
# (see below), which makes mod_dir think "/dashboard" is a directory
# reference and auto-redirect to "/dashboard/" *before* mod_rewrite below
# ever runs — bypassing the .html rewrite entirely. Turn that off; the
# rewrite rules are the only URL normalization we want happening.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>

# Pretty URLs: Turbopack's static export writes each route as a flat
# <route>.html file, but *also* creates a same-named <route>/ folder
# holding internal RSC prefetch payloads (not a browsable page). Serve
# the .html file whenever it exists — deliberately not excluding
# same-named directories, since every real route has one of those
# internal folders sitting right next to it, and excluding them (an
# earlier version of this rule did) makes Apache try to list/serve
# that folder instead and return 403 on every route but "/".
<IfModule mod_rewrite.c>
  RewriteEngine On

  # This build doesn't use trailing slashes (next.config.ts has no
  # trailingSlash: true), so a URL like "/blog/" would otherwise fall
  # through to Apache's directory handling for the internal RSC-payload
  # folder above and 403. Drop the trailing slash first so it lands on
  # the same rule as "/blog".
  RewriteCond %{REQUEST_URI} !^/$
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [L,R=301]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Custom 404 page (Next exports one at build time).
ErrorDocument 404 /404.html
