{
    "name": "yourcompany/ai-chatbot-saas",
    "description": "Enterprise AI Chatbot SaaS Platform (Chatbase-style) - REST API backend",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/http-message": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.7",
        "firebase/php-jwt": "^6.10",
        "ramsey/uuid": "^4.7",
        "nesbot/carbon": "^3.8",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3"
        },
    "audit": {
        "block-insecure": false
    }
},
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "migrate": "php bin/migrate.php",
        "migrate:rollback": "php bin/migrate.php rollback",
        "migrate:fresh": "php bin/migrate.php fresh",
        "seed": "php bin/seed.php",
        "crawl:process": "php bin/process-crawl-jobs.php",
        "test": "phpunit"
    }
}
