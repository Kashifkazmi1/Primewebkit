# Security headers — equivalent to the next.config.ts headers() that
# don't run in static-export mode (no Node.js server to apply them).
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # /chat is meant to be embedded in an iframe on customer sites, so it's
  # excluded from the frame-restriction everything else gets.
  <If "%{REQUEST_URI} !~ m#^/chat#">
    Header always set X-Frame-Options "SAMEORIGIN"
  </If>
</IfModule>

# Pretty URLs: Next's static export writes each route as
# <route>/index.html — serve that file when a visitor requests the
# folder without "/index.html" on the end, and don't force a redirect
# that would strip a trailing slash Next itself doesn't add.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Custom 404 page (Next exports one at build time).
ErrorDocument 404 /404.html
