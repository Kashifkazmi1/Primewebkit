##############################################
# AI Chatbot SaaS Platform - Environment Config
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
##############################################

# ---------------- Application ----------------
APP_NAME="PrimeWebKit"
APP_ENV=production
# Valid: local, development, staging, production
APP_DEBUG=false
# Root site URL. This backend is deployed on its own subdomain
# (api.primewebkit.com), but APP_URL must still point at the FRONTEND
# origin (primewebkit.com) — it's used to build links that open in a
# browser (email verification, password reset), not to describe where
# this API itself runs.
APP_URL=https://primewebkit.com
APP_TIMEZONE=UTC
APP_LOCALE=en
# 32+ character random string used for internal encryption (AES-256-CBC)
APP_KEY=

# ---------------- Database (MySQL 8) ----------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_chatbot_saas
DB_USERNAME=ai_chatbot_user
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

# ---------------- Logging ----------------
LOG_CHANNEL=daily
# Valid: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=info
LOG_DAYS=14
LOG_APP_FILE=storage/Logs/app.log
LOG_API_FILE=storage/Logs/api.log
LOG_AUTH_FILE=storage/Logs/auth.log
LOG_ACTIVITY_FILE=storage/Logs/activity.log
LOG_SYSTEM_FILE=storage/Logs/system.log
LOG_AI_FILE=storage/Logs/ai.log

# ---------------- CORS ----------------
# The frontend (primewebkit.com) and this API (api.primewebkit.com) are
# on different subdomains, so every request from the frontend is
# cross-origin — it must be listed here exactly, or the browser will
# block it. Comma-separate multiple exact origins if you add a staging
# frontend, etc.
CORS_ALLOWED_ORIGINS=https://primewebkit.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-API-Key
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ---------------- Security ----------------
SECURITY_FORCE_HTTPS=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_MAX_ATTEMPTS=60
SECURITY_RATE_LIMIT_DECAY_SECONDS=60
SECURITY_LOGIN_MAX_ATTEMPTS=5
SECURITY_LOGIN_LOCKOUT_MINUTES=15

# ---------------- JWT Authentication ----------------
JWT_SECRET=
JWT_ALGO=HS256
JWT_ISSUER=ai-chatbot-saas
JWT_AUDIENCE=ai-chatbot-saas-clients
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ---------------- Mail ----------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.primewebkit.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@primewebkit.com
MAIL_FROM_NAME="PrimeWebKit"

# ---------------- Google Sign-In ----------------
# Public OAuth client ID (not a secret) for Google Identity Services.
# Must match the frontend's NEXT_PUBLIC_GOOGLE_CLIENT_ID and have
# primewebkit.com registered as an Authorized JavaScript origin in
# Google Cloud Console.
GOOGLE_CLIENT_ID=1044212666179-nmo21qhhgr7hc4n8sdm34ccsgs5sdo84.apps.googleusercontent.com

# ---------------- Google Gemini AI ----------------
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_OUTPUT_TOKENS=2048

# ---------------- File Uploads ----------------
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,text/plain,text/csv,text/markdown,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_STORAGE_PATH=storage/Uploads
KNOWLEDGE_BASE_STORAGE_PATH=storage/KnowledgeBase

# ---------------- Initial Super Admin (used only by the seeder) ----------------
SEED_SUPER_ADMIN_NAME="Platform Owner"
SEED_SUPER_ADMIN_EMAIL=owner@primewebkit.com
SEED_SUPER_ADMIN_PASSWORD=

# ---------------- Stripe (future) ----------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---------------- Billing ----------------
# 'manual' requires no external gateway and is fully functional today.
BILLING_PROVIDER=manual
BILLING_DEFAULT_CURRENCY=USD
BILLING_GRACE_PERIOD_DAYS=7

# ---------------- AI platform tuning ----------------
AI_DEFAULT_PROVIDER=gemini
AI_RAG_TOP_K=5
AI_RAG_MIN_SCORE=0.55
AI_RAG_MAX_CONTEXT_TOKENS=2000
AI_MEMORY_MAX_MESSAGES=20
AI_MEMORY_MAX_TOKENS=3000
AI_CHAT_RATE_LIMIT_MAX_ATTEMPTS=20
AI_CHAT_RATE_LIMIT_DECAY_SECONDS=60

# ---------------- AI provider pricing (per 1,000 tokens; 0 = free tier) ----------------
PRICING_GEMINI_FLASH_PROMPT_PER_1K=0
PRICING_GEMINI_FLASH_COMPLETION_PER_1K=0
PRICING_GEMINI_PRO_PROMPT_PER_1K=0
PRICING_GEMINI_PRO_COMPLETION_PER_1K=0
PRICING_GEMINI_EMBEDDING_PER_1K=0
