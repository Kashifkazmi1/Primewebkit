# This file only matters if your Hostinger hosting plan does not allow
# setting the document root to the /public folder. If you CAN set the
# document root to /public (recommended, e.g. via hPanel > Advanced >
# PHP Configuration / Domains), delete this file — the one inside
# /public is sufficient and more secure.
#
# If you CANNOT change the document root, this file makes the project
# root behave as if /public were the webroot, while still blocking
# direct access to application source, storage and config.

RewriteEngine On

# Block direct access to everything except the public/ folder.
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{REQUEST_URI} !^/index\.php
RewriteRule ^(app|bootstrap|config|database|routes|storage|tests|vendor|docs)(/.*)?$ - [F,L]

# Route every request through public/index.php.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [L]

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

Options -Indexes
